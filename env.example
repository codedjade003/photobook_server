NODE_ENV=development
PORT=5000

# ==================== App Configuration ====================
APP_NAME=Photobook
API_BASE_URL=http://localhost:5000
WEB_BASE_URL=http://localhost:3000

# ==================== Database (PostgreSQL) ====================
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/photobook
PGHOST=localhost
PGPORT=5432
PGDATABASE=photobook
PGUSER=postgres
PGPASSWORD=changeme

# ==================== Redis (Caching & Session Store) ====================
REDIS_URL=redis://localhost:6379
SESSION_STORE_PREFIX=sess:

# ==================== Authentication & JWT ====================
JWT_SECRET=changeme-with-long-random-string
JWT_EXPIRES_IN=30d
BCRYPT_ROUNDS=10
SESSION_SECRET=changeme-with-long-random-string-for-sessions
SESSION_IDLE_TIMEOUT_MINUTES=120
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=120
RATE_LIMIT_USE_REDIS=true

# ==================== Email Configuration (Resend) ====================
# Templates are rendered locally in src/templates/email.templates.js
EMAIL_FEATURE_ENABLED=true
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=no-reply@photobookhq.com
VERIFICATION_CODE_TTL_MINUTES=15
PASSWORD_RESET_CODE_TTL_MINUTES=15
VERIFICATION_MAX_ATTEMPTS=5
VERIFICATION_LOCKOUT_MINUTES=15
VERIFICATION_RESEND_MAX_ATTEMPTS=3
VERIFICATION_RESEND_WINDOW_MINUTES=60
VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# ==================== OAuth (Google) ====================
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ==================== OAuth (Optional: Facebook) ====================
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=

# ==================== OAuth (Optional: Apple) ====================
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=

# ==================== SMS (Twilio - Optional) ====================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ==================== File Storage (Backblaze B2) ====================
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_ID=
B2_BUCKET_NAME=
B2_ENDPOINT=
B2_DOWNLOAD_URL=
B2_SIGNED_URL_TTL_SECONDS=3600

# ==================== Payments (Paystack) ====================
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ==================== Service Health Monitoring ====================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL_MS=300000

# ==================== Supabase (Optional - if using Supabase) ====================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ==================== 2FA Settings ====================
# 2FA is user-configurable; no specific env vars needed here
# But you can add 2FA enforcement levels if desired
TWO_FA_REQUIRED_FOR_ROLE=photographer

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
OPAY_API_KEY=
POCKETAPP_API_KEY=
PLATFORM_COMMISSION_PERCENT=0.12
# Webhooks
PAYMENT_WEBHOOK_SECRET=
# Realtime
SOCKET_IO_PATH=/socket.io
# Feature Limits
MAX_PORTFOLIO_ITEMS=20
MAX_UPLOAD_MB=20
MAX_VIDEO_SECONDS=60
